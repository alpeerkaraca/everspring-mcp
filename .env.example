# 1 -- Model & Tier Configuration ---

# The embedding model tier to use (choices: main, slim, xslim)
# main: BGE-M3 (supports Hybrid Search), slim: BGE-base, xslim: BGE-small
EVERSPRING_EMBED_TIER=main

# The specific embedding model ID to use
EVERSPRING_EMBED_MODEL=BAAI/bge-m3

# Model tier used specifically for S3 snapshot and model artifact paths
EVERSPRING_MODEL_TIER=main

# Parallel workers for document reading and chunk preparation (default: CPU-based, max 16)
EVERSPRING_INDEX_CHUNK_WORKERS=4

# Number of prepared embedding batches to prefetch ahead of GPU consumption
EVERSPRING_INDEX_PREFETCH_BATCHES=3

# Huggingface access token for faster downloads.
HUGGINGFACE_ACCESS_TOKEN=<INSERT_TOKEN>

# --- Vector Database (Chroma) ---

# Persistent directory for ChromaDB data
# Enable if you want static fetching, comment if you want app to decide which dir should be used!!!
# EVERSPRING_CHROMA_DIR=~/.everspring/chroma

# ChromaDB collection name for storing vectors
EVERSPRING_CHROMA_COLLECTION=spring_docs

# Number of vectors to include in each ChromaDB upsert call
EVERSPRING_CHROMA_UPSERT_BATCH_SIZE=512

# --- Server & HTTP ---

# Host address for the HTTP MCP transport server
EVERSPRING_HTTP_HOST=0.0.0.0

# Port number for the HTTP MCP transport server
EVERSPRING_HTTP_PORT=8000

# --- Storage & AWS ---

# Root local directory for all application data (SQLite, docs, etc.)
EVERSPRING_DATA_DIR=~/.everspring

# S3 bucket name for documentation and snapshots
EVERSPRING_S3_BUCKET=everspring-mcp-kb

# AWS region for S3 and other services
AWS_REGION=eu-central-1

# Root S3 key prefix for all stored objects
EVERSPRING_S3_PREFIX=spring-docs

# AWS Access Key ID for authentication (required for S3 access)
AWS_ACCESS_KEY_ID=your_access_key_here

# AWS Secret Access Key for authentication (required for S3 access)
AWS_SECRET_ACCESS_KEY=your_secret_key_here

# --- External Services ---

# GitHub Personal Access Token for documentation ingestion from repos/wikis
GITHUB_TOKEN=<INSERT_TOKEN>

# --- Internal & Debug ---

# Internal flag used to track if the process was automatically restarted during snapshot updates
EVERSPRING_AUTO_SNAPSHOT_RESTARTED=0